{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Files",
  "version": "0.8.3",
  "identifier": "dev.jumarf.files",
  "build": {
    "beforeDevCommand": "npm --prefix ../app run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm --prefix ../app run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../app/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Files — by Jumarf",
        "label": "main",
        "width": 1440,
        "height": 900,
        "minWidth": 1220,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "maximized": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Jumarf",
    "shortDescription": "Deleted-file forensic triage and recovery workbench for Windows.",
    "copyright": "Copyright 2026 Jumarf",
    "licenseFile": "../legal/LICENSE",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "Files"
      }
    }
  }
}
